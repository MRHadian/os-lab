# ==========================================
#  C / C++ compiled objects and binaries
# ==========================================

# Object files
*.o
*.obj
*.pdb
*.ilk

# Precompiled Headers
*.gch
*.pch

# Dynamic libraries
*.so
*.dylib
*.dll

# Static libraries
*.a
*.lib

# Executables (common suffixes)
*.exe
*.out
*.app

